{
  "name": "@react-hooks-toolbox/use-async",
  "version": "1.0.0",
  "description": "Manage async function state in React — part of react-hooks-toolbox",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "keywords": [
    "react",
    "hook",
    "async",
    "fetch",
    "react-hooks-toolbox"
  ],
  "publishConfig": {
    "access": "public"
  }
}
