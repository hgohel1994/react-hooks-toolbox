{
  "name": "react-hooks-toolbox",
  "version": "1.0.0",
  "description": "A collection of useful React custom hooks — install all hooks at once",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@react-hooks-toolbox/use-async": "1.0.0",
    "@react-hooks-toolbox/use-click-outside": "1.0.0",
    "@react-hooks-toolbox/use-copy-to-clipboard": "1.0.0",
    "@react-hooks-toolbox/use-counter": "1.0.0",
    "@react-hooks-toolbox/use-debounce": "1.0.0",
    "@react-hooks-toolbox/use-document-title": "1.0.0",
    "@react-hooks-toolbox/use-event-listener": "1.0.0",
    "@react-hooks-toolbox/use-fetch": "1.0.0",
    "@react-hooks-toolbox/use-hover": "1.0.0",
    "@react-hooks-toolbox/use-intersection-observer": "1.0.0",
    "@react-hooks-toolbox/use-interval": "1.0.0",
    "@react-hooks-toolbox/use-is-mounted": "1.0.0",
    "@react-hooks-toolbox/use-key-press": "1.0.0",
    "@react-hooks-toolbox/use-local-storage": "1.0.0",
    "@react-hooks-toolbox/use-media-query": "1.0.0",
    "@react-hooks-toolbox/use-on-mount": "1.0.0",
    "@react-hooks-toolbox/use-online-status": "1.0.0",
    "@react-hooks-toolbox/use-previous": "1.0.0",
    "@react-hooks-toolbox/use-timeout": "1.0.0",
    "@react-hooks-toolbox/use-toggle": "1.0.0",
    "@react-hooks-toolbox/use-window-size": "1.0.0"
  },
  "keywords": [
    "react",
    "hooks",
    "custom-hooks",
    "react-hooks",
    "toolbox",
    "debounce",
    "localStorage",
    "media-query"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/react-hooks-toolbox"
  }
}
