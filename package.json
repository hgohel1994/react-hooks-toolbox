{
  "name": "react-hooks-toolbox",
  "private": true,
  "version": "1.0.0",
  "description": "A collection of useful React custom hooks — install all or pick individual hooks",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "npm run clean --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.8",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
